#!/bin/sh

# Load husky helper
. "$(dirname "$0")/_/husky.sh"

LOCKFILE="pnpm-lock.yaml"

echo "🔍 Checking if $LOCKFILE is staged for commit..."

# Get full path for safety
STAGED_FILES=$(git diff --cached --name-only | tr -d '\r')

# Debug line (optional)
# echo "Files staged: $STAGED_FILES"

# ตรวจสอบแบบ flexible (รองรับ path หรือ case ที่มี ./)
echo "$STAGED_FILES" | grep -E "(^|/)$LOCKFILE$" > /dev/null

if [ $? -eq 0 ]; then
  echo "✅ $LOCKFILE is staged. Proceeding with commit..."
  exit 0
else
  echo "⚠️ $LOCKFILE has changes but is NOT staged."
  echo "❗ โปรดรัน: git add $LOCKFILE แล้ว commit อีกครั้ง"
  exit 1
fi