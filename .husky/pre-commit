#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔎 Pre-commit checks running..."

# -----------------------------
# Skip if only pnpm-lock.yaml changed
# -----------------------------
if git diff --cached --name-only | grep -q "^pnpm-lock.yaml$"; then
  echo "✅ Only pnpm-lock.yaml changed. Skipping checks..."
  exit 0
fi

# -----------------------------
# TypeScript type-check
# -----------------------------
if git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx)$" > /dev/null; then
  echo "🔎 Running TypeScript type-check..."
  if ! pnpm type-check; then
    echo "❌ TypeScript errors detected. Commit aborted."
    exit 1
  fi
fi

# -----------------------------
# ESLint (only staged files)
# -----------------------------
echo "🔎 Running ESLint..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx|js|jsx)$")
if [ -n "$STAGED_FILES" ]; then
  if ! pnpm eslint $STAGED_FILES --fix; then
    echo "❌ ESLint errors detected. Commit aborted."
    exit 1
  fi
fi

# -----------------------------
# Prettier format (only staged files)
# -----------------------------
echo "🔎 Running Prettier..."
if [ -n "$STAGED_FILES" ]; then
  if ! pnpm prettier --write $STAGED_FILES; then
    echo "❌ Prettier formatting failed. Commit aborted."
    exit 1
  fi
  git add $STAGED_FILES
fi

echo "✅ All checks passed. Proceeding with commit..."
exit 0