{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@home/*": ["Home/*"],
      "@assets/*": ["assets/*"],
      "@styles/*": ["styles/*"],
      "@data/*": ["data/*"],
      "@components/*": ["components/*"],
      "@common/*": ["utils/common/*"],
      "@utils/*": ["utils/*"],
      "@hooks/*": ["hooks/*"],
      "@layout/*": ["Layout/*"],
      "@router/*": ["Router/*"],
      "@api/*": ["api/*"],
      "@services/*": ["services/*"],
      "@__mocks__/*": ["__mocks__/*"],
      "@config/*": ["config/*"]
    },
    "outDir": "../dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
