{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": "src",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/*": ["*"],
      "@home/*": ["Home/*"],
      "@assets/*": ["assets/*"],
      "@styles/*": ["styles/*"],
      "@data/*": ["data/*"],
      "@components/*": ["components/*"],
      "@common/*": ["utils/common/*"],
      "@utils/*": ["utils/*"],
      "@hooks/*": ["hooks/*"],
      "@layout/*": ["Layout/*"],
      "@router/*": ["Router/*"],
      "@api/*": ["api/*"],
      "@services/*": ["services/*"],
      "@__mocks__/*": ["__mocks__/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}