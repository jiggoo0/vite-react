{
  "compilerOptions": {
    // กำหนด Target ของ JavaScript output
    "target": "ES2020",
    // Module system สำหรับ bundler เช่น Vite
    "module": "ESNext",
    "moduleResolution": "node",
    // Libraries ที่ TypeScript จะรู้จัก
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    // การใช้ JSX สำหรับ React 17+ (automatic runtime)
    "jsx": "react-jsx",

    // Base directory สำหรับ paths
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@styles/*": ["src/styles/*"],
      "@data/*": ["src/data/*"],
      "@components/*": ["src/components/*"],
      "@common/*": ["src/utils/common/*"],
      "@utils/*": ["src/utils/*"],
      "@hooks/*": ["src/hooks/*"],
      "@layout/*": ["src/Layout/*"],
      "@router/*": ["src/Router/*"],
      "@home/*": ["src/Home/*"],
      "@api/*": ["src/api/*"]
    },

    // ไดเรกทอรีสำหรับ build output และ root ของ source
    "outDir": "./dist",
    "rootDir": "./src",

    // ความเข้มงวดของ TypeScript
    "strict": true,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true,

    // โมดูล interoperability
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // การตั้งค่าการตรวจสอบไฟล์
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
